FROM python:3.11-slim

WORKDIR /app

# Depth endpoint deps only — fast build, small image
RUN pip install --no-cache-dir \
    "numpy<2" \
    pillow \
    torch \
    torchvision \
    --extra-index-url https://download.pytorch.org/whl/cpu

# ML inference deps
RUN pip install --no-cache-dir \
    "transformers>=4.40,<5.0" \
    "accelerate>=0.30"

# API + worker deps
RUN pip install --no-cache-dir \
    "fastapi>=0.110" \
    "uvicorn[standard]>=0.29" \
    "pydantic>=2,<3" \
<<<<<<< HEAD
    "python-multipart>=0.0.9" \
    "celery[redis]>=5.3" \
    "boto3>=1.34" \
    "psycopg2-binary>=2.9" \
    "sqlalchemy>=2.0" \
    "python-jose[cryptography]>=3.3" \
    "httpx>=0.27"

# Pre-download the depth model into the image so the first request is instant
RUN python -c "\
from transformers import pipeline; \
p = pipeline('depth-estimation', model='depth-anything/Depth-Anything-V2-Small-hf', device=-1); \
print('Model cached.')"

# Copy all Python source files
COPY *.py ./

EXPOSE 8000
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000", \
     "--timeout-keep-alive", "300"]
